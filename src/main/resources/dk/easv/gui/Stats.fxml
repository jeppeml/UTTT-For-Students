<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="650.0" prefWidth="700.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dk.easv.gui.StatsController">
    <!-- Warning banner -->
    <HBox fx:id="warningBanner" alignment="CENTER_LEFT" spacing="8" styleClass="warning-banner">
        <padding><Insets top="6" bottom="6" left="10" right="10" /></padding>
        <Label text="Running simulations against REST bots will stress the server. Use with caution to be fair to everyone." wrapText="true" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" />
        <Button onAction="#clickDismissWarning" styleClass="warning-close" text="X" />
    </HBox>
    <!-- Progress bar -->
    <ProgressBar fx:id="progressBar" maxWidth="1.7976931348623157E308" prefHeight="6" visible="false" />
    <!-- SplitPane: current games vs finished games -->
    <SplitPane orientation="VERTICAL" dividerPositions="0.35" VBox.vgrow="ALWAYS">
        <!-- Top: Current Games -->
        <VBox>
            <Label fx:id="lblCurrentGames" alignment="CENTER" maxWidth="1.7976931348623157E308" styleClass="active-games-label" text="Current Games" />
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="active-games-scroll">
                <FlowPane fx:id="flowActiveGames" hgap="8" vgap="8" styleClass="active-games-flow" />
            </ScrollPane>
        </VBox>
        <!-- Bottom: Finished Games -->
        <VBox>
            <Label alignment="CENTER" maxWidth="1.7976931348623157E308" styleClass="active-games-label" text="Finished Games" />
            <HBox spacing="4" VBox.vgrow="ALWAYS">
                <!-- Player 0 column -->
                <VBox HBox.hgrow="ALWAYS">
                    <Label fx:id="lblP0Name" alignment="CENTER" maxWidth="1.7976931348623157E308" styleClass="stats-player-name" text="Player 0" />
                    <Label fx:id="lblP0Stats" alignment="CENTER" maxWidth="1.7976931348623157E308" styleClass="stats-ratio" />
                    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="active-games-scroll">
                        <FlowPane fx:id="flowP0Wins" hgap="6" vgap="6" styleClass="active-games-flow" />
                    </ScrollPane>
                </VBox>
                <!-- Player 1 column -->
                <VBox HBox.hgrow="ALWAYS">
                    <Label fx:id="lblP1Name" alignment="CENTER" maxWidth="1.7976931348623157E308" styleClass="stats-player-name" text="Player 1" />
                    <Label fx:id="lblP1Stats" alignment="CENTER" maxWidth="1.7976931348623157E308" styleClass="stats-ratio" />
                    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="active-games-scroll">
                        <FlowPane fx:id="flowP1Wins" hgap="6" vgap="6" styleClass="active-games-flow" />
                    </ScrollPane>
                </VBox>
            </HBox>
            <Button maxWidth="1.7976931348623157E308" onAction="#clickClearList" styleClass="action-button" text="Clear list" />
        </VBox>
    </SplitPane>
</VBox>
