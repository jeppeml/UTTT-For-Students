                  <String fx:value="namesetter" />
               </styleClass>
               <GridPane.margin>
                  <Insets left="5.0" right="5.0" />
               </GridPane.margin></TextField>
            <RadioButton fx:id="radioLeftAI" maxWidth="1.7976931348623157E308" onAction="#clickSelector" styleClass="selectors" text="AI" toggleGroup="$toggleLeft" GridPane.columnIndex="1" GridPane.rowIndex="3" GridPane.valignment="CENTER" />
            <ComboBox fx:id="comboBotsLeft" maxWidth="1.7976931348623157E308" prefHeight="25.0" prefWidth="138.0" GridPane.columnIndex="1" GridPane.rowIndex="4" GridPane.valignment="CENTER">
