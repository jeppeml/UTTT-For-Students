               </styleClass>
               <GridPane.margin>
                  <Insets />
               </GridPane.margin></Button>
            <RadioButton fx:id="radioRightHuman" maxWidth="1.7976931348623157E308" onAction="#clickSelector" selected="true" styleClass="selectors" text="Human" GridPane.columnIndex="2" GridPane.rowIndex="3" GridPane.valignment="CENTER">
               <toggleGroup>
                  <ToggleGroup fx:id="toggleRight" />
               </toggleGroup>
            </RadioButton>
            <RadioButton fx:id="radioRightAI" maxWidth="1.7976931348623157E308" onAction="#clickSelector" styleClass="selectors" text="AI" toggleGroup="$toggleRight" GridPane.columnIndex="3" GridPane.rowIndex="3" GridPane.valignment="CENTER" />
