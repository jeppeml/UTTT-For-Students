                  <String fx:value="selectors" />
                  <String fx:value="namesetter" />
               </styleClass>
               <GridPane.margin>
                  <Insets left="5.0" right="5.0" />
               </GridPane.margin></ComboBox>
            <Button fx:id="btnDiamond" contentDisplay="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" text=" " textAlignment="CENTER" GridPane.columnIndex="2" GridPane.columnSpan="2" GridPane.rowIndex="2">
               <styleClass>
                  <String fx:value="player1" />
