               </GridPane.margin></TextField>
            <ComboBox fx:id="comboBotsRight" maxWidth="1.7976931348623157E308" prefHeight="25.0" prefWidth="124.0" GridPane.columnIndex="3" GridPane.rowIndex="4" GridPane.valignment="CENTER">
               <styleClass>
                  <String fx:value="selectors" />
                  <String fx:value="namesetter" />
               </styleClass>
               <GridPane.margin>
                  <Insets left="5.0" right="5.0" />
               </GridPane.margin></ComboBox>
            <Label alignment="CENTER" contentDisplay="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" styleClass="game-headline" text="Diamonds vs Trash" textAlignment="CENTER" GridPane.columnSpan="4" />
            <Slider fx:id="sliderSpeed" blockIncrement="100.0" focusTraversable="false" majorTickUnit="1000.0" max="2500.0" minorTickCount="50" snapToTicks="true" value="2000.0" GridPane.columnIndex="1" GridPane.columnSpan="2" GridPane.rowIndex="1" />
            <Label alignment="CENTER_RIGHT" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" styleClass="selectors" text="Bot speed" GridPane.rowIndex="1" />
            <Button alignment="CENTER_RIGHT" maxHeight="1.7976931348623157E308" onAction="#clickOpenStats" styleClass="action-button" text="Open stats" textAlignment="CENTER" GridPane.columnIndex="3" GridPane.halignment="RIGHT" GridPane.rowIndex="1" />
