            <Slider fx:id="sliderSim" blockIncrement="100.0" disable="true" majorTickUnit="100.0" max="1000.0" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" min="1.0" minorTickCount="5" showTickLabels="true" showTickMarks="true" snapToTicks="true" GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.rowIndex="5">
